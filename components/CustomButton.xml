<component name="CustomButton" extends="Group">
    <interface>
        <field id="isCustomButtonSelected" type="bool" alwaysNotify="true" />
        <field id="width" type="float" onChange="onWidthChanged" />
        <field id="height" type="float" onChange="onHeightChanged" />
        <field id="text" type="string" onChange="onTextChanged" />
    </interface>

    <children>
        <Poster
            id="poster" 
            uri="pkg:/images/white.png" 
            blendColor="#573516" />
        <Label
            id="label" 
            font="font:SmallerBoldSystemFont"
            horizAlign="center"
            vertAlign="center" />
    </children>

    <script type="text/brightscript" uri="pkg:/components/CustomButton.brs" />
</component>
