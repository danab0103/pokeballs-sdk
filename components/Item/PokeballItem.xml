<component name="PokeballItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusStateChanged" />
        <field id="rowListHasFocus" type="boolean" onChange="onFocusStateChanged" />
    </interface>

    <children>
        <Poster
            id="focusPoster"
            uri="pkg:/images/rounded_mask.png"
            blendColor="#90868d"
            width="208"
            height="208"
            visible="false" />

        <MaskGroup 
            id="maskGroup" 
            translation="[4, 4]"
            maskUri="pkg:/images/rounded_mask.png" >

            <Poster
                id="poster"
                width="200"
                height="200"
                loadDisplayMode="scaleToFill" />
        </MaskGroup>
    </children>

    <script type="text/brightscript" uri="pkg:/components/Item/PokeballItem.brs" />
</component>
